VITE_AZURE_CLIENT_ID=your-azure-client-id
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
VITE_AZURE_REDIRECT_URI=http://localhost:8080

# API Configuration - Gateway geral dos microsserviços Lazarus
VITE_API_BASE_URL=https://lazarusapi.azure-api.net

# IAM custom - ms-users no Azure Container Apps
# O login oficial do MVP usa /users/auth/* nesta base dedicada.
VITE_AUTH_API_BASE_URL=https://lazarus-users.proudmeadow-1e583df1.centralus.azurecontainerapps.io

# Para desenvolvimento local integrado, aponte cada base para o serviço correspondente.
# VITE_API_BASE_URL=http://localhost:3001/api/v1
# VITE_AUTH_API_BASE_URL=http://localhost:3001

# Development Configuration
VITE_NODE_ENV=development
