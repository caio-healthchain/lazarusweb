# Azure AD legado mantido apenas para compatibilidade futura/OIDC
VITE_AZURE_CLIENT_ID=your-azure-client-id
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
VITE_AZURE_REDIRECT_URI=http://localhost:8080

# API Configuration - API Gateway dos microsserviços Lazarus
# O login oficial do MVP usa o ms-users em /users/auth/*.
VITE_API_BASE_URL=https://lazarusapi.azure-api.net

# Para desenvolvimento local integrado, aponte para o gateway ou BFF local equivalente.
# VITE_API_BASE_URL=http://localhost:3001/api/v1

# Development Configuration
VITE_NODE_ENV=development
